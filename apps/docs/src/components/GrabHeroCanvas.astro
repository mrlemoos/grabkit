<div class="grab-hero-stage" id="grab-hero-root" aria-hidden="true">
  <canvas class="grab-hero-canvas"></canvas>
</div>

<script>
  import { initGrabHeroScene } from '../scripts/grab-hero-scene';

  function bootGrabHero() {
    const canvas = document.querySelector('#grab-hero-root .grab-hero-canvas');
    if (!(canvas instanceof HTMLCanvasElement)) {
      return;
    }

    if (canvas.dataset.grabHeroReady === 'true') {
      return;
    }
    canvas.dataset.grabHeroReady = 'true';

    const dispose = initGrabHeroScene(canvas);
    document.addEventListener(
      'astro:before-swap',
      () => {
        dispose();
        canvas.dataset.grabHeroReady = 'false';
      },
      { once: true },
    );
  }

  bootGrabHero();
  document.addEventListener('astro:page-load', bootGrabHero);
</script>

<style>
  .grab-hero-stage {
    position: relative;
    width: 100%;
    height: clamp(16rem, 42vw, 26rem);
    margin-inline: auto;
    overflow: visible;
    background: transparent;
  }

  .grab-hero-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
